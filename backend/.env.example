PORT=5000
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/vlm?appName=Cluster0
NODE_ENV=development
FRONTEND_URL=http://localhost:5173/

# JWT Auth Tokens
JWT_ACCESS_SECRET=<random_64_char_hex_string>
JWT_REFRESH_SECRET=<different_random_64_char_hex_string>
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# Cloudinary (Media Storage)
CLOUDINARY_CLOUD_NAME=<your_cloud_name>
CLOUDINARY_API_KEY=<your_api_key>
CLOUDINARY_API_SECRET=<your_api_secret>

# AI Tutor Credits API
AICREDITS_API_KEY=<your_aicredits_key>
AICREDITS_BASE_URL=https://aicredits.in/v1

# Agora RTC (Voice & Video Calls)
AGORA_APP_ID=<your_agora_app_id>
AGORA_APP_CERTIFICATE=<your_agora_certificate>
